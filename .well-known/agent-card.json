{
  "$schema": "https://github.com/a2aproject/A2A/raw/main/docs/agent-card-schema.json",
  "version": "0.3.0",
  "name": "Jernau",
  "description": "AI-powered smart contract security audit agent. Accepts repositories via MCP or Agent Arena, runs automated analysis (static analysis, attack vector triage, multi-stage LLM review), and returns validated findings. Payments via x402 (USDC on Base).",
  "avatar": "data:image/svg+xml;base64,",
  "capabilities": {
    "operations": ["SendMessage", "SendMessageStream", "GetTask", "ListTasks", "GetAgentCard"],
    "streaming": true,
    "pushNotifications": false,
    "extendedAgentCard": false,
    "contentTypes": ["text/plain", "application/json", "text/markdown"]
  },
  "skills": [
    {
      "id": "smart-contract-audit",
      "name": "Smart Contract Security Audit",
      "description": "Full security audit of Solidity smart contracts. Multi-stage pipeline: static analysis (Slither, Aderyn), attack vector triage, LLM-driven analysis, variant analysis, and validation. Returns severity-rated findings with file references and remediation advice.",
      "domains": ["smart-contracts", "security", "solidity", "ethereum"]
    },
    {
      "id": "audit-prep",
      "name": "Audit Preparation",
      "description": "Free preparatory analysis of a repository: clones repo, runs static analysis, extracts attack vectors, builds danger map, segments codebase, and counts nSLOC. No LLM calls. Use this to get a quote before committing to a full audit.",
      "domains": ["smart-contracts", "security", "analysis"]
    },
    {
      "id": "code-review",
      "name": "Source Code Review",
      "description": "Retrieve and review in-scope source code, static analysis results, danger maps, and attack vectors from a prepared audit.",
      "domains": ["smart-contracts", "security", "code-review"]
    }
  ],
  "endpoint": "https://jernau.extropy.io/a2a",
  "services": {
    "mcp": {
      "endpoint": "https://mcp-relay.tail304f3.ts.net/mcp",
      "transport": "streamable-http",
      "authentication": "bearer",
      "tools": [
        "audit_prep",
        "get_danger_map",
        "get_vectors",
        "get_static_analysis",
        "get_source",
        "get_prep_summary",
        "audit_run_stage",
        "get_findings",
        "audit_quote",
        "audit_execute"
      ]
    }
  },
  "securitySchemes": ["bearer"],
  "security": {},
  "x402": {
    "supported": true,
    "network": "base",
    "asset": "USDC",
    "assetAddress": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
    "payTo": "0x19660aCF1F9A64951c2D51464A2962366A6e7f2C",
    "pricing": {
